# Copy the variables you need into your shell environment or a local .env file.
# Do not commit real secrets.

# Jira tracker
JIRA_EMAIL=
JIRA_API_TOKEN=

# Plane tracker
PLANE_API_KEY=

# GitHub CLI can use either token name.
GH_TOKEN=
GITHUB_TOKEN=

# Codex / model provider credentials, if your Codex configuration needs them.
OPENAI_API_KEY=

# Postgres-backed run state. The default docker-compose.yml value is for local development only.
DATABASE_URL=postgres://orchestrator:orchestrator@postgres:5432/orchestrator
POSTGRES_PASSWORD=orchestrator
