# Copy the variables you need into your shell environment or a local .env file.
# Do not commit real secrets.

# Jira tracker
JIRA_EMAIL=
JIRA_API_TOKEN=

# Plane tracker
PLANE_API_TOKEN=

# GitHub CLI can use either token name.
GH_TOKEN=
GITHUB_TOKEN=

# Codex / model provider credentials, if your Codex configuration needs them.
OPENAI_API_KEY=

# Claude Code, if agent.kind is claude-code.
ANTHROPIC_API_KEY=

# Optional Postgres-backed run state. The default Compose quick start uses JSON state in /data.
DATABASE_URL=
